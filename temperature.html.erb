      font-size: 18px;
      color: #660000;
      background-color: #f4f4f4;
      padding: 10px;
      border-radius: 5px;
  }
  .color{
      background-color: #660000;
      height: 100px;
      width: 100px;
      
  }
  
  </style>
</head>
<body>

<p class="text">Введіть температуру⭣</p>
<label>
