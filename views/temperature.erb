<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>Температура</title>
  <style>
      .text {
          font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
          font-size: 18px;
          color: #660000;
          background-color: #f4f4f4;
          padding: 10px;
          border-radius: 5px;
          display: inline-block;
          margin-bottom: 5px;
      }
      .color {
          height: 100px;
          width: 100px;
          margin-top: 15px;
          border-radius: 5px;
      }
      .input {
          font-family: 'JetBrains Mono', monospace;
          padding: 8px;
          border: 1px solid #660000;
          border-radius: 5px;
      }
      .but {
          background-color: #660000;
          color: white;
          padding: 8px 15px;
          border: none;
          border-radius: 5px;
          cursor: pointer;
      }
      .but:hover {
          background-color: #880000;
      }
  </style>
</head>
<body>

<p class="text">Введіть температуру ⭣</p>

<form method="GET" action="/temperature">
  <input 
    class="input" 
    name="temp" 
    placeholder="Введіть число" 
    value="<%= @temp %>">
  <button class="but" type="submit">Перевірити</button>
</form>

<hr>

<% if @temp && !@temp.strip.empty? %>
  <% if @temp.strip.match?(/^-?\d+$/) %>
    <% t = @temp.to_i %>

    <% 
      if t >= 20
        result = "Температура висока 🔥"
        color = "red"
      elsif t >= 10
        result = "Середня 🌤️"
        color = "orange"
      else
        result = "Низька ❄️"
        color = "blue"
      end
    %>

    <p class="text">Результат: <%= result %></p>
    <div class="color" style="background-color: <%= color %>;"></div>

  <% else %>
    <p class="text">Помилка: Введіть коректне число ⚠️</p>
  <% end %>
<% end %>

</body>
</html>
