<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Анкета</title>
    <style>
        /* 1. Налаштування всієї сторінки */
        body {
            background-color: #f4f4f9; 
            font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh; /* Центрування по висоті */
            margin: 0;
            color: #333;
        }

        .form-card {
            background: white;
            padding: 30px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            text-align: center;
        }

        /* Стиль для поля вводу */
        .input-field {
            font-family: inherit;
            color: #660000;
            padding: 10px;
            border: 2px solid #ddd;
            border-radius: 8px;
            outline: none;
            transition: 0.3s;
        }

        .input-field:focus {
            border-color: #ff4d4d;
        }

        /* Стиль для кнопки (твоя кнопка в стилі Apple) */
        .btn-main {
            background-color: #ff4d4d; 
            color: white;              
            padding: 10px 25px;       
            border: none;             
            border-radius: 8px;       
            font-size: 16px;          
            cursor: pointer;          
            transition: 0.3s;
            font-family: inherit;
            margin-left: 10px;
        }

        .btn-main:hover {
            background-color: #e63939; 
            transform: scale(1.05);    
        }

        #greeting {
            margin-top: 20px;
            font-weight: bold;
            font-size: 20px;
            color: #ff4d4d;
        }
    </style>
</head>
<body>

    <div class="form-card">
        <h1>Анкета</h1>
        
        <div class="input-group">
            <input type="text" id="nameInput" class="input-field" placeholder="Введіть ім'я...">
            <button type="button" class="btn-main" onclick="showHi()">Hi</button>
        </div>

        <div id="greeting"></div>
    </div>

    <script>
        function showHi() {
            const name = document.getElementById('nameInput').value;
            const output = document.getElementById('greeting');
            
            if (name.trim() !== "") {
                output.innerText = "HI, " + name.toUpperCase() + "!";
            } else {
                output.innerText = "Введіть ім'я, будь ласка";
            }
        }
    </script>

</body>
</html>
