<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <title>Анкета</title>
    <style>
.input{
    font-family: 'JetBrains Mono', 'Fira Code', 'Courier New', monospace;
    color: #660000;
}

.but {
    background-color: #ff4d4d; /* Червоний колір, як у Apple або твого бренду */
    color: white;              /* Білий текст */
    padding: 10px 25px;       /* Відступи всередині (кнопка стане більшою) */
    border: none;             /* Прибираємо стандартну чорну рамку */
    border-radius: 8px;       /* Закруглені кути */
    font-size: 16px;          /* Розмір тексту */
    cursor: pointer;          /* Курсор стає "рукою" при наведенні */
    transition: 0.3s;         /* Плавна анімація */
}

.but:hover {
    background-color: #e63939; /* Трохи темніший колір, коли наводиш мишкою */
    transform: scale(1.05);    /* Кнопка злегка збільшується */
}
/* 1. Налаштування всієї сторінки */
body {
    background-color: #f4f4f9; /* Світло-сірий фон */
    font-family: 'JetBrains Mono', monospace;
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 50px;
    color: #333;
}
</style>
</head>
<body class="body">

    <div class="form-card">
        <h1>Анкета</h1>
        
        <div class="input-group">
            <input type="text" id="nameInput" class="input-field" placeholder="Введіть ім'я...">
            <button type="button" class="btn-main" onclick="showHi()">Hi</button>
        </div>

        <div id="greeting"></div>
    </div>

    <script>
        // Ця функція бере текст із поля і показує його на екрані
        function showHi() {
            const name = document.getElementById('nameInput').value;
            const output = document.getElementById('greeting');
            
            if (name.trim() !== "") {
                output.innerText = "HI, " + name + "!";
            } else {
                output.innerText = "Введіть ім'я, будь ласка";
            }
        }
    </script>

</body>
</html>
